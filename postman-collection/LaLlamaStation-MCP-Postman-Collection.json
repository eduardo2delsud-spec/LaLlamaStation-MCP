{
  "info": {
    "name": "LaLlamaStation MCP - API Collection",
    "description": "Coleccion completa de endpoints de LaLlamaStation MCP\n\nBase URL: http://localhost:3000\nAutenticacion: x-api-key header o Authorization: Bearer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0",
    "exporter": {
      "name": "Postman",
      "version": "10.0.0"
    }
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "default"
    },
    {
      "key": "api_key",
      "value": "mcp_test_key",
      "type": "default"
    },
    {
      "key": "model",
      "value": "qwen3.5:4b",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "1. Models (OpenAI Compatible)",
      "item": [
        {
          "name": "List Models (v1/models)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/models",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "models"
              ]
            },
            "description": "Listar todos los modelos instalados en formato OpenAI compatible"
          },
          "response": []
        },
        {
          "name": "List Models (API Format)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/models",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "models"
              ]
            },
            "description": "Listar modelos con detalles completos"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Chat & Completions",
      "item": [
        {
          "name": "Chat Completions (Non-Streaming)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful assistant.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Hola, como te llamas?\"\n    }\n  ],\n  \"stream\": false,\n  \"temperature\": 0.7,\n  \"num_ctx\": 2048,\n  \"top_p\": 0.9,\n  \"top_k\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            },
            "description": "Enviar prompt y recibir respuesta (modo no-streaming)"
          },
          "response": []
        },
        {
          "name": "Chat Completions (Streaming)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{model}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Explica brevemente que es Machine Learning\"\n    }\n  ],\n  \"stream\": true,\n  \"temperature\": 0.7,\n  \"num_ctx\": 2048,\n  \"top_p\": 0.9,\n  \"top_k\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/chat/completions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "chat",
                "completions"
              ]
            },
            "description": "Enviar prompt y recibir respuesta en streaming (Server-Sent Events)"
          },
          "response": []
        }
      ]
    },
