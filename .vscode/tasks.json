{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Frontend",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"presentation": {
				"group": "lallamaollama",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Start Backend",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true,
			"presentation": {
				"group": "lallamaollama",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Start Brain",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/mcp-brain"
			},
			"isBackground": true,
			"presentation": {
				"group": "lallamaollama",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "🚀 Start LaLlamaOllama",
			"dependsOn": ["Start Frontend", "Start Backend", "Start Brain"],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		}
	]
}
