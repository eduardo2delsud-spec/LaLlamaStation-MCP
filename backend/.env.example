# LaLlamaOllama Server - Environment Configuration
# ===================================================

# Master Key for authentication (Required)
# Used by the frontend, MCP clients, and OpenAI compatible endpoints
API_KEY=YOUR_SECURE_API_KEY_HERE

# Port where the server will run (Default: 3000)
APP_PORT=3000

# Base URL for the internal Ollama engine (Docker/Local)
# For Docker: http://mcp-ollama-motor:11434
# For Localhost: http://127.0.0.1:11434
OLLAMA_API_URL=http://127.0.0.1:11434

# Container name for Ngrok tunnel control
NGROK_CONTAINER_NAME=mcp-ngrok-tunnel
